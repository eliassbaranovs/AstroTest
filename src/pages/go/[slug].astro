---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const [casinoEntries, bonusEntries] = await Promise.all([
    getCollection("casinos"),
    getCollection("bonuses"),
  ]);
  const seen = new Map<string, { casinoName: string; claimUrl: string }>();
  for (const post of [...casinoEntries, ...bonusEntries]) {
    const { casino, casinoName, claim_url } = post.data;
    if (casino && claim_url && !seen.has(casino)) {
      seen.set(casino, { casinoName: casinoName ?? casino, claimUrl: claim_url });
    }
  }
  return Array.from(seen.entries()).map(([slug, props]) => ({
    params: { slug },
    props,
  }));
}

interface Props {
  casinoName: string;
  claimUrl: string;
}
const { casinoName, claimUrl } = Astro.props;
---

<Layout
  title={`Redirecting to ${casinoName}…`}
  robots="noindex, nofollow"
  noIndex={true}
>
  <div class="redirect-page">
    <p class="redirect-page__message">Redirecting you to <strong>{casinoName}</strong>…</p>
    <p class="redirect-page__sub">If you are not redirected automatically, <a href={claimUrl} rel="nofollow sponsored" target="_blank">click here</a>.</p>
  </div>
  <script define:vars={{ claimUrl }}>
    setTimeout(() => { window.location.href = claimUrl; }, 1500);
  </script>
</Layout>

<style>
  .redirect-page {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    text-align: center;
    gap: 0.75rem;
    padding: 2rem;
  }
  .redirect-page__message { font-size: 1.4rem; font-weight: 600; color: #eef0fa; }
  .redirect-page__sub { color: #7a7fa0; font-size: 0.95rem; }
</style>
