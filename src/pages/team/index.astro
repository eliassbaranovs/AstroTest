---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const authors = await getCollection("authors");
const allCasinos = await getCollection("casinos");
const allBonuses = await getCollection("bonuses");

// Count articles per author
const articleCount = new Map<string, number>();
for (const entry of [...allCasinos, ...allBonuses]) {
  const slug = entry.data.authorSlug;
  if (slug) articleCount.set(slug, (articleCount.get(slug) ?? 0) + 1);
}
---

<Layout
  title="Our Casino Experts"
  description="Meet the team of certified iGaming specialists who write and verify every casino review and bonus analysis on CasinoRank."
  canonical="https://casinorank.com/team/"
>
  <div class="container team-page">
    <header class="team-header">
      <h1>Our Casino Experts</h1>
      <p class="team-header__lead">
        Every review you read on CasinoRank is written and fact-checked by a specialist with
        real hands-on experience. Meet the analysts behind the ratings.
      </p>
    </header>

    <div class="team-grid">
      {authors.map((author) => {
        const d = author.data;
        const count = articleCount.get(d.slug) ?? 0;
        return (
          <a href={`/team/${d.slug}/`} class="team-card">
            <img
              src={d.avatar}
              alt={`${d.name} — ${d.role ?? "Casino Analyst"}`}
              width="96"
              height="96"
              loading="lazy"
              decoding="async"
              class="team-card__avatar"
              onerror="this.src='/images/authors/placeholder.png'"
            />
            <div class="team-card__body">
              <strong class="team-card__name">{d.name}</strong>
              {d.role && <span class="team-card__role">{d.role}</span>}
              <p class="team-card__bio">
                {d.bio.length > 100 ? d.bio.slice(0, 97) + "…" : d.bio}
              </p>
              {d.expertise?.length && (
                <ul class="team-card__tags">
                  {d.expertise.slice(0, 3).map((e) => <li>{e}</li>)}
                </ul>
              )}
              <span class="team-card__count">{count} article{count !== 1 ? "s" : ""}</span>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</Layout>

<style>
  .team-page {
    padding-top: 3rem;
    padding-bottom: 4rem;
  }

  .team-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .team-header h1 {
    font-size: clamp(1.6rem, 4vw, 2.25rem);
    color: #eef0fa;
    margin-bottom: 0.75rem;
  }

  .team-header__lead {
    color: #7a80a0;
    max-width: 520px;
    margin: 0 auto;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .team-card {
    background: #13131f;
    border: 1px solid #2a2a40;
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    text-decoration: none;
    transition: border-color 0.2s, transform 0.2s;
  }

  .team-card:hover {
    border-color: #f0c040;
    transform: translateY(-2px);
  }

  .team-card__avatar {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid #f0c040;
    margin-bottom: 1rem;
  }

  .team-card__body {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    width: 100%;
  }

  .team-card__name {
    font-size: 1.05rem;
    color: #eef0fa;
  }

  .team-card__role {
    font-size: 0.78rem;
    color: #f0c040;
    background: rgba(240, 192, 64, 0.1);
    padding: 0.15rem 0.6rem;
    border-radius: 4px;
  }

  .team-card__bio {
    font-size: 0.85rem;
    color: #7a80a0;
    margin: 0.35rem 0;
    line-height: 1.5;
  }

  .team-card__tags {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.35rem;
  }

  .team-card__tags li {
    font-size: 0.72rem;
    color: #585d7a;
    background: #1a1a2e;
    border: 1px solid #2a2a40;
    padding: 0.1rem 0.45rem;
    border-radius: 3px;
  }

  .team-card__count {
    font-size: 0.78rem;
    color: #585d7a;
    margin-top: 0.25rem;
  }
</style>
