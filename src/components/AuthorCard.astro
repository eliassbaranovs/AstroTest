---
interface Props {
  name: string;
  slug: string;
  bio: string;
  avatar: string;
  role?: string;
  credentials?: string[];
}

const { name, slug, bio, avatar, role, credentials } = Astro.props;

// Truncate bio to ~120 chars for card display
const bioSnippet = bio.length > 120 ? bio.slice(0, 117) + "…" : bio;
---

<div class="author-card">
  <a href={`/team/${slug}/`} class="author-avatar-link" aria-label={`View ${name}'s profile`}>
    <img
      src={avatar}
      alt={`${name} — ${role ?? "Casino Analyst"}`}
      width="64"
      height="64"
      loading="lazy"
      decoding="async"
      class="author-avatar"
      onerror="this.src='/images/authors/placeholder.png'"
    />
  </a>
  <div class="author-info">
    <div class="author-meta">
      <a href={`/team/${slug}/`} class="author-name">{name}</a>
      {role && <span class="author-role">{role}</span>}
    </div>
    <p class="author-bio">{bioSnippet}</p>
    {credentials && credentials.length > 0 && (
      <ul class="author-credentials">
        {credentials.map((c) => <li>{c}</li>)}
      </ul>
    )}
    <a href={`/team/${slug}/`} class="author-profile-link">View full profile →</a>
  </div>
</div>

<style>
  .author-card {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    background: #13131f;
    border: 1px solid #2a2a40;
    border-left: 3px solid #f0c040;
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    margin: 2rem 0;
  }

  .author-avatar-link {
    flex-shrink: 0;
  }

  .author-avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid #f0c040;
  }

  .author-info {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .author-meta {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .author-name {
    font-size: 1rem;
    font-weight: 700;
    color: #f0c040;
    text-decoration: none;
  }
  .author-name:hover {
    text-decoration: underline;
  }

  .author-role {
    font-size: 0.78rem;
    color: #9999bb;
    background: #1e1e30;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
  }

  .author-bio {
    margin: 0;
    font-size: 0.88rem;
    color: #b0b0c8;
    line-height: 1.5;
  }

  .author-credentials {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .author-credentials li {
    font-size: 0.75rem;
    color: #7a7a99;
    background: #1a1a2e;
    padding: 0.1rem 0.5rem;
    border-radius: 3px;
    border: 1px solid #2a2a40;
  }

  .author-profile-link {
    font-size: 0.8rem;
    color: #f0c040;
    text-decoration: none;
    margin-top: 0.15rem;
    align-self: flex-start;
  }
  .author-profile-link:hover {
    text-decoration: underline;
  }

  @media (max-width: 600px) {
    .author-card {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .author-meta {
      justify-content: center;
    }

    .author-credentials {
      justify-content: center;
    }

    .author-profile-link {
      align-self: center;
    }
  }
</style>
