---
interface Props {
  rating: number;  // 0–10
  size?: "sm" | "md" | "lg";
}
const { rating, size = "md" } = Astro.props;
const pct = Math.round((rating / 10) * 100);
const colour = rating >= 8 ? "#4cda7a" : rating >= 6 ? "#f0c040" : "#e05050";
---

<div class={`rating rating--${size}`} aria-label={`Rating: ${rating} out of 10`}>
  <span class="rating__number" style={`color:${colour}`}>{rating.toFixed(1)}</span>
  <div class="rating__bar-track">
    <div class="rating__bar-fill" style={`width:${pct}%;background:${colour}`}></div>
  </div>
</div>

<style>
  .rating { display: flex; align-items: center; gap: 0.6rem; }
  .rating__number { font-weight: 700; line-height: 1; }
  .rating--sm .rating__number { font-size: 1rem; }
  .rating--md .rating__number { font-size: 1.5rem; }
  .rating--lg .rating__number { font-size: 2rem; }
  .rating__bar-track {
    flex: 1;
    height: 6px;
    background: rgba(255 255 255 / 0.1);
    border-radius: 99px;
    overflow: hidden;
    min-width: 60px;
  }
  .rating__bar-fill { height: 100%; border-radius: 99px; transition: width 0.3s; }
</style>
